{
  "datasets": [
    {
      "name": "d1fb0a2f",
      "displayName": "Exames com Pacientes",
      "queryLines": [
        "SELECT\n",
        "  e.*,\n",
        "  p.nome,\n",
        "  p.idade,\n",
        "  p.sexo,\n",
        "  p.medico_solicitante\n",
        "FROM\n",
        "  exames e\n",
        "    LEFT JOIN pacientes p\n",
        "      ON e.cpf = p.cpf"
      ],
      "catalog": "cosin_aws_serverless_catalog",
      "schema": "exames_clinicos"
    }
  ],
